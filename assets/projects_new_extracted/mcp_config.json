{
  "mcpServers": [
    {
      "name": "legado-book-source-tamer",
      "description": "Legado书源驯兽师 - 智能书源开发助手，支持自动化分析网站结构并生成Legado书源JSON",
      "command": "python",
      "args": [
        "-m",
        "uvicorn",
        "src.main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "5000"
      ],
      "env": {
        "PYTHONPATH": ".",
        "COZE_WORKSPACE_PATH": "."
      },
      "disabled": false
    }
  ],
  "tools": [
    {
      "name": "smart_fetch_html",
      "description": "智能获取网页HTML，支持GET/POST等各种请求方法。功能特点：支持所有HTTP方法、支持自定义headers、支持Cookies、支持请求体、自动重试机制、超时控制。",
      "category": "网页获取",
      "parameters": {
        "url": {
          "type": "string",
          "description": "请求URL（必填）"
        },
        "method": {
          "type": "string",
          "description": "HTTP方法（默认GET，可选：POST, PUT, DELETE等）"
        },
        "params": {
          "type": "string",
          "description": "URL参数（JSON字符串格式，可选）"
        },
        "data": {
          "type": "string",
          "description": "请求体（表单数据，JSON字符串格式，可选）"
        },
        "headers": {
          "type": "string",
          "description": "自定义headers（JSON字符串格式，可选）"
        },
        "cookies": {
          "type": "string",
          "description": "Cookies（JSON字符串格式，可选）"
        }
      },
      "returns": {
        "type": "string",
        "description": "请求结果报告，包含请求信息、HTML内容、验证结果等"
      }
    },
    {
      "name": "get_full_html",
      "description": "获取网页完整HTML源代码，不进行任何截断。确保获取真实的、完整的HTML源代码用于分析。",
      "category": "网页获取",
      "parameters": {
        "url": {
          "type": "string",
          "description": "请求URL"
        },
        "method": {
          "type": "string",
          "description": "HTTP方法（默认GET）"
        },
        "params": {
          "type": "string",
          "description": "URL参数（JSON字符串格式）"
        },
        "data": {
          "type": "string",
          "description": "请求体（JSON字符串格式）"
        },
        "headers": {
          "type": "string",
          "description": "自定义headers（JSON字符串格式）"
        },
        "cookies": {
          "type": "string",
          "description": "Cookies（JSON字符串格式）"
        }
      },
      "returns": {
        "type": "string",
        "description": "完整HTML源代码"
      }
    },
    {
      "name": "test_request_method",
      "description": "测试网站支持哪些HTTP方法，找到正确的请求方式。测试GET、POST、PUT、DELETE、HEAD、OPTIONS等方法。",
      "category": "网页获取",
      "parameters": {
        "url": {
          "type": "string",
          "description": "请求URL"
        },
        "method": {
          "type": "string",
          "description": "要测试的方法（默认GET）"
        }
      },
      "returns": {
        "type": "string",
        "description": "测试结果，显示每种方法的测试结果"
      }
    },
    {
      "name": "search_knowledge",
      "description": "搜索知识库，查询CSS选择器、书源规则、POST请求配置等知识。⚠️ 重要提醒：搜索结果仅供参考，不能直接照搬知识库中的选择器，所有选择器必须在真实HTML上验证。",
      "category": "知识库",
      "parameters": {
        "query": {
          "type": "string",
          "description": "搜索关键词"
        },
        "category": {
          "type": "string",
          "description": "知识类别（可选）"
        },
        "limit": {
          "type": "integer",
          "description": "返回结果数量（默认5）"
        }
      },
      "returns": {
        "type": "string",
        "description": "知识条目列表，包含标题、内容、示例等（仅供参考）"
      }
    },
    {
      "name": "get_book_source_examples",
      "description": "获取书源示例，查看实际书源中的规则示例。从知识库中查找书源示例，显示特定元素类型的规则，提供多个实际书源的参考。",
      "category": "知识库",
      "parameters": {
        "element_type": {
          "type": "string",
          "description": "元素类型（bookinfo、toc、content、search等）"
        },
        "limit": {
          "type": "integer",
          "description": "返回示例数量（默认3）"
        }
      },
      "returns": {
        "type": "string",
        "description": "书源示例列表"
      }
    },
    {
      "name": "check_knowledge_status",
      "description": "检查知识库学习状态，查看学习进度和状态。显示知识库学习状态、统计已学习的知识数量、显示应用统计。",
      "category": "知识库",
      "parameters": {},
      "returns": {
        "type": "string",
        "description": "知识状态报告"
      }
    },
    {
      "name": "learn_knowledge_base",
      "description": "学习知识库，让AI真正学会书源开发知识。读取assets目录下的所有知识文件，解析并学习书源规则、CSS选择器、技术文档，构建知识关联和索引。⚠️ 重要提醒：知识库内容仅作参考，不能直接照搬知识库中的选择器，所有选择器必须在真实HTML上验证。",
      "category": "知识库",
      "parameters": {
        "force": {
          "type": "boolean",
          "description": "是否强制重新学习（默认False）"
        }
      },
      "returns": {
        "type": "string",
        "description": "学习统计和状态报告"
      }
    },
    {
      "name": "smart_web_analyzer",
      "description": "智能分析网站整体结构。自动分析网站的HTML结构，识别关键元素（书名、作者、封面、目录、正文等），提供结构分析报告。",
      "category": "智能分析",
      "parameters": {
        "html": {
          "type": "string",
          "description": "HTML内容"
        },
        "page_type": {
          "type": "string",
          "description": "页面类型（search、list、detail、toc、content等）"
        }
      },
      "returns": {
        "type": "string",
        "description": "结构分析报告"
      }
    },
    {
      "name": "smart_bookinfo_analyzer",
      "description": "智能分析书籍详情页结构。分析书籍详情页的HTML结构，提取书名、作者、封面、简介、分类、最新章节等信息。",
      "category": "智能分析",
      "parameters": {
        "html": {
          "type": "string",
          "description": "书籍详情页HTML"
        }
      },
      "returns": {
        "type": "string",
        "description": "详情页分析报告"
      }
    },
    {
      "name": "smart_toc_analyzer",
      "description": "智能分析目录页结构。分析目录页的HTML结构，提取章节列表、章节名称、章节URL等信息。",
      "category": "智能分析",
      "parameters": {
        "html": {
          "type": "string",
