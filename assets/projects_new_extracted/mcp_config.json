      "parameters": {
        "html": {
          "type": "string",
          "description": "正文页HTML"
        }
      },
      "returns": {
        "type": "string",
        "description": "正文页分析报告"
      }
    },
    {
      "name": "smart_full_analyzer",
      "description": "综合分析器，完整分析网站所有页面。一次性分析搜索、列表、详情、目录、正文等所有页面结构。",
      "category": "智能分析",
      "parameters": {
        "html": {
          "type": "string",
          "description": "HTML内容"
        }
      },
      "returns": {
        "type": "string",
        "description": "完整分析报告"
      }
    },
    {
      "name": "edit_book_source",
      "description": "编辑书源，生成完整的书源JSON。使用complete_source参数一次性创建完整书源，包含搜索、列表、详情、目录、正文等所有规则。",
      "category": "书源编辑",
