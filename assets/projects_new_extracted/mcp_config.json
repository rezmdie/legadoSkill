  "metadata": {
    "version": "1.0.0",
    "name": "Legado书源驯兽师",
    "author": "Kilo Code",
    "description": "Legado书源驯兽师 - 智能书源开发助手，支持自动化分析网站结构并生成Legado书源JSON。基于LangChain和LangGraph，拥有24.93MB知识库，167个文档，134个真实书源分析结果。",
    "homepage": "https://github.com/yourusername/legado-book-source-tamer",
