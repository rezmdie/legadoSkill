      "returns": {
        "type": "string",
        "description": "调试结果"
      }
    },
    {
      "name": "legado_debug_book_source",
      "description": "使用Legado调试器调试书源。基于Legado官方源码的规则解析器，支持Default、XPath、JsonPath、正则等多种规则类型。",
      "category": "调试",
      "parameters": {
        "book_source_json": {
          "type": "string",
          "description": "书源JSON字符串"
        },
